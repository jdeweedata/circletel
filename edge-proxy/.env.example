# MikroTik Edge Proxy Configuration
# Copy to .env and fill in values

# Server
PORT=8443

# API Authentication
PROXY_API_KEY=your-api-key-here
PROXY_HMAC_SECRET=your-hmac-secret-here

# Default MikroTik credentials
MIKROTIK_DEFAULT_USER=thinkadmin
MIKROTIK_DEFAULT_PASS=your-router-password

# Allowed IP ranges (Vercel)
# PROXY_ALLOWED_IPS=76.76.21.0/24

# SSL (optional, for HTTPS)
# SSL_CERT_PATH=/etc/ssl/proxy/cert.pem
# SSL_KEY_PATH=/etc/ssl/proxy/key.pem
