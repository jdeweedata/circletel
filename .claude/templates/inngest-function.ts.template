 *
 * Triggers:
 * - Event: '{{EVENT_NAMESPACE}}/{{EVENT_NAME}}.requested'
 * - Cron: {{CRON_SCHEDULE}} (optional, remove if not needed)
 */

import { inngest } from '../client';
import { createClient } from '@/lib/supabase/server';

// =============================================================================
// TYPES
